@page
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div style="max-width:420px; margin:48px auto 0;">

    <div style="text-align:center; margin-bottom:32px;">
        <h1 style="font-size:28px; letter-spacing:-0.5px; margin-bottom:8px;">Create your account</h1>
        <p class="muted" style="font-size:15px;">Get started with TeamCollab for free.</p>
    </div>

    <div class="card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-error" role="alert" style="margin-bottom:20px;"></div>

            <div class="form-group">
                <label asp-for="Input.DisplayName">Display Name</label>
                <input asp-for="Input.DisplayName" type="text" autocomplete="nickname" placeholder="How others will find you" />
                <span asp-validation-for="Input.DisplayName" class="field-validation-error"></span>
                <p class="muted" style="font-size:12px; margin-top:6px;">This is your public name - others can use it to add you to projects.</p>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:24px;">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-primary" style="width:100%;">Create account</button>
        </form>
    </div>

    <p style="text-align:center; font-size:14px; color:var(--muted); margin-top:20px;">
        Already have an account?
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
    </p>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
