@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div style="max-width:520px; margin:0 auto;">

    <div class="page-header">
        <div>
            <h1>Account Settings</h1>
            <p class="muted" style="margin-top:4px; font-size:14px;">Manage your profile and security settings.</p>
        </div>
    </div>

    @* Tab navigation between profile and password pages. *@
    <div style="display:flex; gap:4px; border-bottom:1px solid var(--border); margin-bottom:28px;">
        <a href="/Identity/Account/Manage"
           style="padding:8px 16px; font-size:14px; font-weight:500; border-bottom:2px solid transparent; color:var(--muted); margin-bottom:-1px; text-decoration:none;">
            Profile
        </a>
        <a href="/Identity/Account/Manage/ChangePassword"
           style="padding:8px 16px; font-size:14px; font-weight:500; border-bottom:2px solid var(--accent); color:var(--text); margin-bottom:-1px; text-decoration:none;">
            Password
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="card">
        <form method="post">
            <div class="form-group">
                <label asp-for="Input.OldPassword">Current Password</label>
                <input asp-for="Input.OldPassword" type="password" autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.OldPassword" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.NewPassword">New Password</label>
                <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" placeholder="At least 6 characters" />
                <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:24px;">
                <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" placeholder="Repeat new password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-error" style="margin-bottom:16px;"></div>

            <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
