@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div style="max-width:420px; margin:48px auto 0;">

    <div style="text-align:center; margin-bottom:32px;">
        <h1 style="font-size:28px; letter-spacing:-0.5px; margin-bottom:8px;">Welcome back</h1>
        <p class="muted" style="font-size:15px;">Sign in to your TeamCollab account.</p>
    </div>

    <div class="card">
        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-error" role="alert" style="margin-bottom:20px;"></div>

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:12px;">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:8px;">
                <label class="checkbox-row" style="font-size:14px;">
                    <input asp-for="Input.RememberMe" type="checkbox" />
                    Remember me
                </label>
                <a asp-page="./ForgotPassword" style="font-size:14px;">Forgot password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn btn-primary" style="width:100%;">Sign in</button>
        </form>
    </div>

    <p style="text-align:center; font-size:14px; color:var(--muted); margin-top:20px;">
        Don't have an account?
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one for free here!</a>
    </p>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
