@model TeamCollabApp.Models.Project
@{ ViewData["Title"] = Model.Name; Layout = "_Layout"; }

<div style="max-width:520px; margin:64px auto 0; text-align:center; padding:0 24px;">

    <div style="display:inline-flex; align-items:center; gap:6px; background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2); border-radius:20px; padding:4px 14px; font-size:12px; font-weight:700; color:var(--success); letter-spacing:0.8px; text-transform:uppercase; margin-bottom:20px;">
        ✓ You've joined
    </div>

    <h1 style="font-size:28px; letter-spacing:-0.5px; margin-bottom:10px;">@Model.Name</h1>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="muted" style="font-size:15px; line-height:1.7; margin-bottom:0;">@Model.Description</p>
    }

    <hr class="divider" style="margin:32px 0;">

    <div class="card" style="text-align:left; margin-bottom:16px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
            <span class="badge badge-viewer">Viewer</span>
            <span class="muted" style="font-size:13px;">You're viewing as a guest</span>
        </div>
        <p class="muted" style="font-size:14px; line-height:1.65;">
            You have read-only access to this project. Create an account to unlock more - like being invited as an Editor or Commenter.
        </p>
    </div>

    <div class="card" style="border-color:rgba(108,99,255,0.2); background:rgba(108,99,255,0.04); text-align:left;">
        <h3 style="margin-bottom:8px;">Why create an account?</h3>
        <ul style="list-style:none; display:flex; flex-direction:column; gap:8px; margin-bottom:20px;">
            @foreach (var item in new[] {
                "Manage and create your own projects",
                "Get invited as an Editor or a Commenter",
                "Keep your access across devices",
                "Your sessions won't expire",
            })
            {
                <li style="display:flex; gap:10px; font-size:14px; color:var(--muted);">
                    <span style="color:var(--accent); font-weight:700;">✓</span>
                    @item
                </li>
            }
        </ul>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">Create free account</a>
            <a class="btn btn-ghost" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
        </div>
    </div>

    <p class="muted" style="font-size:13px; margin-top:20px;">
        Project by <strong style="color:var(--text);">@Model.Owner.DisplayName</strong>
    </p>
</div>
